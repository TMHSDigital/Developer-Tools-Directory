{
  "accent": "#7c3aed",
  "accentLight": "#a78bfa",
  "heroGradientFrom": "#0d1117",
  "heroGradientTo": "#161b22",
  "links": {
    "github": "https://github.com/{{ repo_owner }}/{{ repo_name }}"
  },
  "installSteps": [
{% if type == 'cursor-plugin' %}
    "Open Cursor IDE and go to <code>Settings</code> > <code>Extensions</code>",
    "Search for <code>{{ name }}</code>",
    "Click <code>Install</code> and reload"
{% else %}
    "Install with <code>npx -y @{{ repo_owner | lower }}/{{ slug }}</code>",
    "Add to your Claude Desktop or Cursor mcpServers config",
    "Restart your MCP client"
{% endif %}
  ]
}
