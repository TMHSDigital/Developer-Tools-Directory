{
  "name": "{{ slug }}",
  "displayName": "{{ name }}",
  "description": "{{ description }}",
  "version": "0.1.0",
  "author": {
    "name": "{{ author_name }}",
    "email": "{{ author_email }}"
  },
  "license": "{{ license_spdx }}",
  "keywords": [
    "cursor-plugin",
    "developer-tools",
    "mcp"
  ],
  "skills": [
{% for skill in skills %}
    "skills/{{ skill }}/SKILL.md"{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "rules": [
{% for rule in rules %}
    "rules/{{ rule }}.mdc"{% if not loop.last %},{% endif %}

{% endfor %}
  ]
}
